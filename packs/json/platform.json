{
  "category": "platform",
  "packs": [
    {
      "id": "platform.github",
      "name": "GitHub Platform",
      "description": "Protects against destructive GitHub CLI operations like deleting repositories, gists, releases, or SSH keys.",
      "keywords": [
        "gh"
      ],
      "structural_patterns": [
        {
          "name": "gh-repo-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "repo"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "gh repo delete permanently deletes a GitHub repository. This cannot be undone.",
          "severity": "critical"
        },
        {
          "name": "gh-repo-archive",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "repo"
            ],
            "arg_exact": [
              "archive"
            ]
          },
          "reason": "gh repo archive makes a repository read-only. While reversible, it stops all write access.",
          "severity": "critical"
        },
        {
          "name": "gh-gist-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "gist"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "gh gist delete permanently deletes a Gist.",
          "severity": "critical"
        },
        {
          "name": "gh-release-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "release"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "gh release delete permanently deletes a release.",
          "severity": "critical"
        },
        {
          "name": "gh-issue-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "issue"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "gh issue delete permanently deletes an issue.",
          "severity": "critical"
        },
        {
          "name": "gh-ssh-key-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "ssh-key"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "gh ssh-key delete removes an SSH key, potentially breaking access.",
          "severity": "critical"
        },
        {
          "name": "gh-secret-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "secret"
            ],
            "arg_exact": [
              "delete",
              "remove"
            ]
          },
          "reason": "gh secret delete removes GitHub Actions secrets.",
          "severity": "critical"
        },
        {
          "name": "gh-variable-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "variable"
            ],
            "arg_exact": [
              "delete",
              "remove"
            ]
          },
          "reason": "gh variable delete removes GitHub Actions variables.",
          "severity": "critical"
        },
        {
          "name": "gh-repo-deploy-key-delete",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "repo"
            ],
            "arg_exact": [
              "deploy-key"
            ],
            "arg_contains": [
              "delete"
            ]
          },
          "reason": "gh repo deploy-key delete removes a deploy key and can break access.",
          "severity": "critical"
        },
        {
          "name": "gh-run-cancel",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "run"
            ],
            "arg_exact": [
              "cancel"
            ]
          },
          "reason": "gh run cancel stops a workflow run and may interrupt deployments.",
          "severity": "critical"
        },
        {
          "name": "gh-api-delete-actions-secret",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "actions/secrets"
            ]
          },
          "reason": "gh api DELETE actions/secrets removes GitHub Actions secrets.",
          "severity": "critical"
        },
        {
          "name": "gh-api-delete-actions-variable",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "actions/variables"
            ]
          },
          "reason": "gh api DELETE actions/variables removes GitHub Actions variables.",
          "severity": "critical"
        },
        {
          "name": "gh-api-delete-hook",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "hooks/"
            ]
          },
          "reason": "gh api DELETE hooks removes repository webhooks.",
          "severity": "critical"
        },
        {
          "name": "gh-api-delete-deploy-key",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "keys/"
            ]
          },
          "reason": "gh api DELETE keys removes deploy keys.",
          "severity": "critical"
        },
        {
          "name": "gh-api-delete-release",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "releases/"
            ]
          },
          "reason": "gh api DELETE releases removes GitHub releases.",
          "severity": "critical"
        },
        {
          "name": "gh-api-delete-repo",
          "when": {
            "command": [
              "gh"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ]
          },
          "reason": "gh api DELETE calls can be destructive. Please verify the endpoint.",
          "severity": "critical"
        }
      ]
    },
    {
      "id": "platform.gitlab",
      "name": "GitLab Platform",
      "description": "Protects against destructive GitLab platform operations like deleting projects, releases, protected branches, and webhooks.",
      "keywords": [
        "glab",
        "gitlab-rails",
        "gitlab-rake"
      ],
      "structural_patterns": [
        {
          "name": "glab-repo-delete",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "repo"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "glab repo delete permanently deletes a GitLab project.",
          "severity": "critical"
        },
        {
          "name": "glab-repo-archive",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "repo"
            ],
            "arg_exact": [
              "archive"
            ]
          },
          "reason": "glab repo archive makes a GitLab project read-only.",
          "severity": "critical"
        },
        {
          "name": "glab-release-delete",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "release"
            ],
            "arg_exact": [
              "delete"
            ]
          },
          "reason": "glab release delete removes GitLab releases.",
          "severity": "critical"
        },
        {
          "name": "glab-variable-delete",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "variable"
            ],
            "arg_exact": [
              "delete",
              "remove"
            ]
          },
          "reason": "glab variable delete removes GitLab CI/CD variables.",
          "severity": "critical"
        },
        {
          "name": "glab-api-delete-project",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "projects/"
            ]
          },
          "reason": "glab api DELETE /projects/* deletes a GitLab project.",
          "severity": "critical"
        },
        {
          "name": "glab-api-delete-release",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "releases/"
            ]
          },
          "reason": "glab api DELETE releases removes GitLab releases.",
          "severity": "critical"
        },
        {
          "name": "glab-api-delete-variable",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "variables/"
            ]
          },
          "reason": "glab api DELETE variables removes CI/CD variables.",
          "severity": "critical"
        },
        {
          "name": "glab-api-delete-protected-branch",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "protected_branches/"
            ]
          },
          "reason": "glab api DELETE protected_branches removes branch protections.",
          "severity": "critical"
        },
        {
          "name": "glab-api-delete-hook",
          "when": {
            "command": [
              "glab"
            ],
            "subcommand": [
              "api"
            ],
            "flag": [
              "-X",
              "--method"
            ],
            "arg_exact": [
              "DELETE"
            ],
            "arg_contains": [
              "hooks/"
            ]
          },
          "reason": "glab api DELETE hooks removes GitLab webhooks.",
          "severity": "critical"
        },
        {
          "name": "gitlab-rails-runner-destructive",
          "when": {
            "command": [
              "gitlab-rails"
            ],
            "subcommand": [
              "runner"
            ],
            "arg_contains": [
              "destroy_all",
              "delete_all",
              "truncate",
              "drop",
              ".destroy",
              ".delete"
            ]
          },
          "reason": "gitlab-rails runner destructive operations can remove data.",
          "severity": "critical"
        },
        {
          "name": "gitlab-rake-backup-restore",
          "when": {
            "command": [
              "gitlab-rake"
            ],
            "arg_contains": [
              "backup:restore"
            ]
          },
          "reason": "gitlab-rake backup:restore replaces the current database with a backup.",
          "severity": "critical"
        },
        {
          "name": "gitlab-rake-db-destructive",
          "when": {
            "command": [
              "gitlab-rake"
            ],
            "arg_contains": [
              "db:drop",
              "db:reset"
            ]
          },
          "reason": "gitlab-rake db:drop/reset destroys the database.",
          "severity": "critical"
        },
        {
          "name": "gitlab-rake-cleanup",
          "when": {
            "command": [
              "gitlab-rake"
            ],
            "arg_contains": [
              "cleanup:"
            ]
          },
          "reason": "gitlab-rake cleanup tasks can delete data.",
          "severity": "critical"
        }
      ]
    }
  ]
}
